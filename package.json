{
  "name": "second-brain-os",
  "version": "0.1.1",
  "type": "module",
  "description": "Second Brain OS — local-first CLI: Markdown vault + SQLite index for capture, organize, search, and review",
  "license": "MIT",
  "keywords": [
    "cli",
    "second-brain-os",
    "second-brain",
    "pkm",
    "markdown",
    "sqlite",
    "knowledge-management",
    "para",
    "notes",
    "local-first"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "second-brain-os": "dist/cli/index.js",
    "second-brain": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "drizzle",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NourEldinShobier/second-brain-os.git"
  },
  "bugs": {
    "url": "https://github.com/NourEldinShobier/second-brain-os/issues"
  },
  "homepage": "https://github.com/NourEldinShobier/second-brain-os#readme",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "dev": "tsc -p tsconfig.build.json --watch",
    "dev:run": "node scripts/dev-run.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "migrate": "node scripts/migrate-placeholder.mjs",
    "db:generate": "drizzle-kit generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1",
    "gray-matter": "^4.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
